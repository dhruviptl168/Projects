          "text": [
            "Enter how many numbers: 3\n",
            "Enter a number: 2\n",
            "Enter a number: 33\n",
            "Enter a number: 5\n",
            "[2, 33, 5]\n",
            "40\n"
          ]
        }
      ],
      "source": [
        "numbers = []\n",
        "\n",
        "n = int(input(\"Enter how many numbers: \"))\n",
        "\n",
        "for i in range(n):\n",
        "    num = int(input(\"Enter a number: \"))\n",
        "    numbers.append(num)\n",
        "\n",
        "total = 0\n",
        "for i in numbers:\n",
        "    total = total + i\n",
        "\n",
        "print(numbers)\n",
        "print(total)\n"
      ]
    }
